import setuptools

with open("README.md", "r") as fh:
    long_description = fh.read()

setuptools.setup(
    name="mchroot",
    packages=["mchroot"],
    version="##VERSION##",
    author="Coffnix (MacaroniOS)"
    author_email="raphael@vipnix.com.br",
    description="MacaroniOS cross-architecture chroot tool (forked from fchroot created by Daniel Robbins).",
    long_description=long_description,
    long_description_content_type="text/markdown",
    url="https://github.com/coffnix/mchroot",
    scripts=['bin/mchroot'],
    classifiers=[
        "Programming Language :: Python :: 3",
        "License :: OSI Approved :: Apache Software License",
        "Operating System :: POSIX :: Linux",
    ],
    python_requires='>=3.7',
)
